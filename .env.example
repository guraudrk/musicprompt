# Copy this file to .env.local.
# Never commit the real .env.local file.

# Matches docker-compose.yml's default local Postgres credentials.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/music_prompt_architect

# Auth.js (NextAuth v5) session secret. Generate with `pnpm exec auth secret` or
# `openssl rand -base64 33`. Required in production; also set locally.
AUTH_SECRET=REPLACE_WITH_A_RANDOM_SECRET

# Create a new Gemini key after revoking any key exposed in chat or source control.
GEMINI_API_KEY=REPLACE_WITH_A_NEW_KEY

# Verified against ai.google.dev and the installed @google/genai package's own types (2026-07-14,
# DECISIONS.md ADR-028): gemini-3.5-flash is what today's official docs pair with the Interactions
# API. gemini-2.5-flash is the older but still GA-stable (until Oct 2026) alternative. Re-verify
# before assuming this is still current — model availability changes (ADR-018).
GEMINI_MODEL=gemini-3.5-flash

# "interactions" names the Interactions API (client.interactions.create), the current recommended
# way to get structured JSON output from @google/genai. Verified real, not a placeholder (ADR-028).
GEMINI_API_MODE=interactions

APP_URL=http://localhost:3000
