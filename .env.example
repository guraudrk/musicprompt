# Copy this file to .env.local.
# Never commit the real .env.local file.

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/music_prompt_architect

# Create a new Gemini key after revoking any key exposed in chat or source control.
GEMINI_API_KEY=REPLACE_WITH_A_NEW_KEY

# Verify the current supported model in the official Gemini documentation.
GEMINI_MODEL=REPLACE_WITH_CURRENT_SUPPORTED_MODEL

# Keep the API mode configurable so the adapter can migrate.
GEMINI_API_MODE=interactions

APP_URL=http://localhost:3000
